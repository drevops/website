{#
/**
 * @file
 * DrevOps service-detail card (services page promo).
 *
 * Renders the promo as the design's structured service-detail card: a header
 * (number, title, tagline), a two-column body (description and the "what's
 * included" list) and a footer (price and CTA button). The parts are split out
 * of the rich-text body in includes/promo.inc.
 */
#}
{% set theme_class = 'ct-theme-%s'|format(paragraph.field_c_p_theme.value|default('dark')) %}
<div class="ct-promo ct-service-detail {{ theme_class }}">
  <div class="container">
    <div class="ct-service-detail__inner">
      <div class="ct-service-detail__header">
        <span class="ct-service-detail__number" aria-hidden="true"></span>
        <div class="ct-service-detail__heading">
          <h2 class="ct-service-detail__title">{{ sd_title }}</h2>
          {% if sd_tagline %}
            <p class="ct-service-detail__tagline">{{ sd_tagline }}</p>
          {% endif %}
        </div>
      </div>

      <div class="ct-service-detail__body">
        <div class="ct-service-detail__desc">{{ sd_description }}</div>
        {% if sd_includes %}
          <div class="ct-service-detail__includes">
            <p class="ct-service-detail__includes-label">What's included</p>
            <ul>
              {% for item in sd_includes %}
                <li>{{ item }}</li>
              {% endfor %}
            </ul>
          </div>
        {% endif %}
      </div>

      {% if sd_price_value or sd_link_url %}
        <div class="ct-service-detail__footer">
          {% if sd_price_value %}
            <div class="ct-service-detail__pricing">
              <span class="ct-service-detail__price-label">{{ sd_price_label }}</span>
              <span class="ct-service-detail__price-value">{{ sd_price_value }}</span>
            </div>
          {% endif %}
          {% if sd_link_url %}
            <a class="ct-button {{ theme_class }} ct-button--secondary ct-button--large" href="{{ sd_link_url }}">{{ sd_link_title }}</a>
          {% endif %}
        </div>
      {% endif %}
    </div>
  </div>
</div>
